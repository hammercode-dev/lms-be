###############################################
# 1. AUTHENTICATION
###############################################

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "password123"
}

###############################################
# 2. EVENT MANAGEMENT
###############################################

### Get Events List (Public)
GET {{baseUrl}}/public/events
Content-Type: application/json

### Get Events List with Pagination
GET {{baseUrl}}/public/events?page=1&limit=10
Content-Type: application/json

### Get Events List with Filter
GET {{baseUrl}}/public/events?type=Tech Talk&status=soon
Content-Type: application/json

### Get Event Detail
GET {{baseUrl}}/public/events/6
Content-Type: application/json

###############################################
# 3. TRANSACTION & REGISTRATION
###############################################

### Create Transaction & Register Event
POST {{baseUrl}}/transactions
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "event_id": 7
}

### Check Payment Status
GET {{baseUrl}}/transactions/{{transactionNo}}/status
Authorization: Bearer {{tokenUser}}

###############################################
# 4. REGISTRATION LIST (User)
###############################################

### Get User Registration List
GET {{baseUrl}}/events/registrations
Authorization: Bearer {{tokenUser}}

### Get User Registration List with Pagination
GET {{baseUrl}}/events/registrations?page=1&limit=10
Authorization: Bearer {{token}}


### Simulate Xendit Webhook - Payment Success
POST {{baseUrl}}/public/webhooks/xendit
Content-Type: application/json
x-callback-token: your-xendit-webhook-token

{
  "external_id": "TRX-1730987654",
  "status": "PAID",
  "payment_method": "CREDIT_CARD",
  "paid_at": "2025-11-07T15:30:00Z"
}

###
### Simulate Xendit Webhook - Payment Failed
POST {{baseUrl}}/public/webhooks/xendit
Content-Type: application/json
x-callback-token: your-xendit-webhook-token

{
  "external_id": "TRX-1730987654",
  "status": "FAILED",
  "payment_method": "CREDIT_CARD",
  "paid_at": null
}

###
### Simulate Xendit Webhook - Payment Expired
POST {{baseUrl}}/public/webhooks/xendit
Content-Type: application/json
x-callback-token: your-xendit-webhook-token

{
  "external_id": "TRX-1730987654",
  "status": "EXPIRED",
  "payment_method": null,
  "paid_at": null
}

###############################################
# 9. ADMIN - REGISTRATION MANAGEMENT
###############################################

### Get Registrations by Event (Admin)
GET {{baseUrl}}/admin/events/6/registrations?page=1&limit=10
Authorization: Bearer {{token}}

